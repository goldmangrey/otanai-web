VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_ENABLE_SSE_CHAT=false

# SSE chat currently requires signed-in mode because /v1/stream-chat requires a Firebase ID token.
# Keep false for guest/local-first fallback testing.

# Staging:
# VITE_API_BASE_URL=https://<staging-backend-url>

# Production:
# VITE_API_BASE_URL=https://<production-backend-url>

# Firebase web config placeholders. Do not commit real project values here.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Leave unset for Production MVP. Cloud chat history is not part of Stage 13.
VITE_CHAT_PERSISTENCE_LIST_PATH=
VITE_CHAT_PERSISTENCE_SYNC_PATH=

# OtanAI Rich Response — Design/Owner Mode
# Vite env vars are build-time values. Restart the dev server or rebuild after changing them.
VITE_ENABLE_RICH_RESPONSE_DESIGN_MODE=true
VITE_ENABLE_RICH_RENDERER=true
VITE_ENABLE_STREAM_PROTOCOL_V4=true
VITE_ENABLE_RICH_RESPONSE_PLAYGROUND=true
VITE_ENABLE_STREAM_SMOOTH_REVEAL=true
VITE_SHOW_RICH_RENDERER_DEBUG=false
VITE_RICH_RENDER_INLINE_SOURCES=false

# Rollback
# VITE_ENABLE_RICH_RESPONSE_DESIGN_MODE=false
# VITE_ENABLE_RICH_RENDERER=false
# VITE_ENABLE_STREAM_PROTOCOL_V4=false
# VITE_ENABLE_STREAM_SMOOTH_REVEAL=false
# VITE_RICH_RENDER_INLINE_SOURCES=false
